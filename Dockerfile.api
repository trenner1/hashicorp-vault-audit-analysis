FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o vault-audit ./cmd/vault-audit/
RUN CGO_ENABLED=0 GOOS=linux go build -o server ./cmd/server/

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /app/vault-audit .
COPY --from=builder /app/server .
RUN mkdir -p uploads
ENV VAULT_AUDIT_BINARY=/app/vault-audit
ENV PORT=8080
EXPOSE 8080
CMD ["./server"]
